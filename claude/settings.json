{
  "env": {
  },
  "permissions": {},
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify_when_stopped.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify_when_stopped.py"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv"
      ]
    },
    "network": {
        "allowedDomains": [
          "pypi.org",
          "files.pythonhosted.org"
        ]
    }
  },
  "alwaysThinkingEnabled": true,
  "theme": "light"
}
