#!/usr/bin/env bash
set -e
set -u
set -o pipefail

# Since we've set `hooksDir` in ~/.gitconfig
GIT_REPO_DIR_ABSOLUTE="$(git rev-parse --show-toplevel)"
GIT_DOT_DIR_RELATIVE="$(git rev-parse --git-common-dir)" # $GIT_DIR is no longer set in hooks (https://stackoverflow.com/a/53121209/118608)
GIT_DIR="$GIT_REPO_DIR_ABSOLUTE/$GIT_DOT_DIR_RELATIVE"

# During a rebase, `git rebase --continue` commits the resolved conflict
# without running the `pre-commit` hook, so leftover conflict markers can
# sneak into a commit. `prepare-commit-msg` *does* run for that commit (and
# aborts it if we exit non-zero), so guard it here. We only check while a
# rebase is actually in progress to leave normal commits untouched.
# (`--git-path` resolves the rebase state dir correctly inside worktrees.)
if [ -d "$(git rev-parse --git-path rebase-merge)" ] || \
   [ -d "$(git rev-parse --git-path rebase-apply)" ]; then
    # Look at the staged diff for added lines that are conflict markers.
    # Same regex as `git-check-conflict-markers`: added line (one or more
    # `+` for combined diffs), optional leading whitespace, then a bare
    # `<<<<<<<` / `=======` / `>>>>>>>` marker. `|| true` keeps the plain
    # `grep` from tripping `set -e`/`pipefail` when there is no match.
    markers="$(git diff --cached --unified=0 --diff-filter=d \
        | grep -v '^+++' \
        | grep -E '^\+{1,}[[:space:]]*(<{7}([[:space:]]|$)|={7}[[:space:]]*$|>{7}([[:space:]]|$))' \
        || true)"
    if [ -n "$markers" ]; then
        echo "prepare-commit-msg: refusing to commit leftover conflict markers during rebase:" >&2
        git diff --cached --check >&2 || true
        echo "Resolve the conflict markers, 'git add' the files, then re-run 'git rebase --continue'." >&2
        exit 1
    fi
fi

if [ -f "$GIT_DIR/hooks/prepare-commit-msg" ]; then
    "$GIT_DIR/hooks/prepare-commit-msg"
fi

exit 0
