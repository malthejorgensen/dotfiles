#!/usr/bin/env bash
# git-check-conflict-markers
#
# Checks the commits on a branch (by default the current branch, compared
# against the repo's default branch) for added lines that contain leftover
# conflict markers (<<<<<<<, =======, >>>>>>>). The commits to check are
# determined by git-list-branch-commits.
#
# For every offending commit, prints its oneline (`<hash> <subject>`).
#
# Usage:
#   git-check-conflict-markers [branch] [base-branch]
#
# Exit status: 0 if no commits contain conflict markers, 1 if one or more do.

set -euo pipefail

branch="${1:-HEAD}"
base_branch="${2:-}"

if [ -n "$base_branch" ]; then
    commits=$(git list-branch-commits "$branch" "$base_branch" --raw)
else
    commits=$(git list-branch-commits "$branch" --raw)
fi

found=0
for commit in $commits; do
    # Only look at added lines (`+...`, one or more `+` to also catch merge
    # commits' combined-diff format), ignore the `+++ b/file` diff header,
    # allow leading whitespace (indented markers), and allow trailing
    # whitespace/CR before end-of-line (CRLF files) after the bare `=======`.
    # Use plain `grep` redirected to /dev/null rather than `grep -q`: with
    # `set -o pipefail`, `grep -q` exits at the first match and the upstream
    # `grep -v` then dies with SIGPIPE (141), making the whole pipeline
    # non-zero and the `if` wrongly conclude "no match". Plain grep reads to
    # EOF, so no stage is killed and the exit status is accurate.
    if git show --unified=0 --pretty=format: "$commit" \
        | grep -v '^+++' \
        | grep -E '^\+{1,}[[:space:]]*(<{7}([[:space:]]|$)|={7}[[:space:]]*$|>{7}([[:space:]]|$))' >/dev/null; then
        git log -1 --oneline "$commit"
        found=1
    fi
done

exit "$found"
